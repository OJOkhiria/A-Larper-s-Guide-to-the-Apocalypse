[sub_resource type="Resource" id="Resource_golbo"]
script = ExtResource("4_rks4u")
text = "In the year 2067, college admissions reached an all-time high level of competitiveness."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_kgeka"]
script = ExtResource("4_rks4u")
text = "Students began training for the application process like it was a sport, and only the most performative survived."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_dt4lh"]
script = ExtResource("4_rks4u")
text = "Rudimentary projects weren't enough to demonstrate merit anymore, giving some the bright idea to create things with much more...        impact."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_rks4u"]
script = ExtResource("4_rks4u")
text = "Their hearts were not truly in this ideation process, though, leading some to cause more harm than good."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_nh2cg"]
script = ExtResource("4_rks4u")
text = "You, though...     were not part of this heartlessness."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_ja504"]
script = ExtResource("4_rks4u")
speaker_img = ExtResource("6_dt4lh")
speaker_img_rest_frame = 1
text = "Thus, you created me: R.E.A.L. the Reactive Empathetic Assistance Logic model."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_wnude"]
script = ExtResource("4_rks4u")
speaker_img = ExtResource("7_rks4u")
text = "Not everyone's like you, though; Especially not the kids at your school."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_4tna5"]
script = ExtResource("4_rks4u")
speaker_img = ExtResource("8_nh2cg")
text = "I mean, seriously, what's a kid like you doing at a school called \"Larper High School for the Performative?\""
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_v6nf2"]
script = ExtResource("4_rks4u")
speaker_img = ExtResource("9_ja504")
text = "One of your classmates decided it'd be a good idea to make bombs and give them to underprivileged kids so they could \"fight back,\" and now the whole world's in a state of anarchy!"
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

[sub_resource type="Resource" id="Resource_gr7rr"]
script = ExtResource("4_rks4u")
speaker_img = ExtResource("7_rks4u")
text = "Point is, things aren't looking too good right now, and I know it's confusing. But if you listen to me, we can fix this mess."
text_speed = 14.0
text_sound = ExtResource("5_nh2cg")
metadata/_custom_type_script = "uid://q2hfxekwglu3"

